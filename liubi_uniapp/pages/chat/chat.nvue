.modal-member { flex-direction: row; align-items: center; padding-top: 8px; padding-bottom: 8px; border-bottom-width: 1px; border-bottom-color: #f8f8f8; }
.modal-av { width: 36px; height: 36px; border-radius: 18px; margin-right: 10px; align-items: center; justify-content: center; }
