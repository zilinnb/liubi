.nav-left { width: 44px; height: 44px; align-items: center; justify-content: center; }
.back-icon { width: 24px; height: 24px; }
.nav-center { flex: 1; flex-direction: row; align-items: baseline; justify-content: center; }
.nav-title { font-size: 17px; font-weight: 700; color: #222; }
.nav-sub { font-size: 13px; color: #999; margin-left: 2px; }
.nav-right { width: 44px; height: 44px; align-items: center; justify-content: center; }
.nav-more { width: 44px; height: 44px; align-items: center; justify-content: center; }
.more-dots { font-size: 22px; color: #333; letter-spacing: 1px; }

/* 消息列表 */
.chat-scroll { flex: 1; background-color: #ebebeb; }
.msg-time-divider { align-items: center; padding-top: 10px; padding-bottom: 4px; }
.time-divider-text { font-size: 12px; color: #999; background-color: rgba(0,0,0,0.04); padding-top: 2px; padding-bottom: 2px; padding-left: 10px; padding-right: 10px; border-radius: 4px; }

.msg-row { flex-direction: row; align-items: flex-start; padding-top: 4px; padding-bottom: 4px; padding-left: 12px; padding-right: 12px; }
.msg-other { justify-content: flex-start; }
.msg-self { justify-content: flex-end; }
.msg-recalled { flex-direction: row; align-items: center; justify-content: center; padding-top: 6px; padding-bottom: 6px; }
.recalled-text { font-size: 12px; color: #999; }
.recalled-edit { font-size: 12px; color: #576b95; margin-left: 4px; }

.msg-system { flex-direction: row; align-items: center; justify-content: center; padding-top: 8px; padding-bottom: 8px; }
.system-text { font-size: 12px; color: #999; background-color: #f5f5f5; border-radius: 4px; padding-top: 4px; padding-bottom: 4px; padding-left: 12px; padding-right: 12px; }

.msg-av { width: 40px; height: 40px; border-radius: 20px; flex-shrink: 0; align-items: center; justify-content: center; background-color: #e8e8e8; }
.msg-av-self { background-color: #ff2442; align-items: center; justify-content: center; }
.av-letter { font-size: 14px; color: #fff; font-weight: 700; }
.msg-other .msg-av { margin-right: 8px; }
.msg-self .msg-av { margin-left: 8px; }

.self-spacer { flex: 1; }

.bubble-wrap { max-width: 260px; }
.self-bubble-wrap { flex-shrink: 1; }
.bubble-sender { font-size: 11px; color: #576b95; margin-bottom: 2px; }
.bubble { border-radius: 4px; padding-top: 10px; padding-bottom: 10px; padding-left: 12px; padding-right: 12px; position: relative; }
.bubble-other { background-color: #ffffff; }
.bubble-self { background-color: #95ec69; }
.bubble-textarea { font-size: 16px; color: #333; line-height: 22px; background-color: transparent; }
.bubble-textarea-self { color: #222; }
.bubble-img-wrap { background-color: transparent; padding: 2px; border-radius: 4px; }
.bubble-image { width: 200px; border-radius: 4px; }

/* 输入栏 - 微信风格 */
.input-bar { background-color: #f7f7f7; border-top-width: 0.5px; border-top-color: #d9d9d9; }
.input-row { flex-direction: row; align-items: flex-end; padding-top: 8px; padding-bottom: 8px; padding-left: 10px; padding-right: 10px; }
.input-wrap { flex: 1; background-color: #ffffff; border-radius: 4px; padding-top: 8px; padding-bottom: 8px; padding-left: 10px; padding-right: 10px; min-height: 36px; max-height: 100px; border-width: 0.5px; border-color: #dddddd; justify-content: center; }
.chat-input { font-size: 16px; min-height: 20px; max-height: 80px; line-height: 20px; }
/* 无输入时的+号按钮 */
.plus-btn { width: 36px; height: 36px; align-items: center; justify-content: center; margin-left: 8px; background-color: #ffffff; border-radius: 4px; border-width: 0.5px; border-color: #dddddd; }
.plus-btn-icon { width: 22px; height: 22px; }
/* 发送按钮 - 只在有输入时显示 */
.send-btn { height: 36px; border-radius: 4px; align-items: center; justify-content: center; padding-left: 14px; padding-right: 14px; margin-left: 8px; }
.send-active { background-color: #07c160; }
.send-text { font-size: 15px; font-weight: 600; }
.send-text-active { color: #ffffff; }

/* 长按菜单 */
.action-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 999; }
.action-box { position: fixed; width: 240px; background-color: rgba(60, 60, 60, 0.95); border-radius: 6px; padding-top: 8px; padding-bottom: 8px; }
