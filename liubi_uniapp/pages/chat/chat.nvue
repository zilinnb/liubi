.modal-leave-btn { margin-top: 8px; margin-bottom: 16px; margin-left: 16px; margin-right: 16px; padding-top: 12px; padding-bottom: 12px; border-radius: 8px; background-color: #fff0f0; align-items: center; justify-content: center; }
.modal-leave-text { font-size: 15px; color: #ff2442; font-weight: 600; }
</style>
